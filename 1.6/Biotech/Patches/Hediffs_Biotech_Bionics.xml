<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- ================================================================
       PASS 1: Ensure every target HediffDef has a <comps> node.
       DetoxifierLung and DetoxifierKidney have no <comps> in vanilla.
       ================================================================ -->

  <Operation Class="PatchOperationConditional">
    <xpath>Defs/HediffDef[defName="DetoxifierLung"]/comps</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/HediffDef[defName="DetoxifierLung"]</xpath>
      <value><comps /></value>
    </nomatch>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>Defs/HediffDef[defName="DetoxifierKidney"]/comps</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/HediffDef[defName="DetoxifierKidney"]</xpath>
      <value><comps /></value>
    </nomatch>
  </Operation>

  <!-- ================================================================
       PASS 2: Add rechargeable comp.
       Both have partEfficiency 1.10; depleted offset of -0.60 leaves 50%.
       ================================================================ -->

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/HediffDef[defName="DetoxifierLung" or defName="DetoxifierKidney"]/comps</xpath>
    <value>
      <li Class="Chargeable_Hediffs_Framework.HediffCompProperties_Rechargeable">
        <maxCharge>100</maxCharge>
        <chargeDecayPerTick>0.0001666667</chargeDecayPerTick>
        <depletedConsequences>
          <partEfficiencyOffset>-0.60</partEfficiencyOffset>
        </depletedConsequences>
      </li>
    </value>
  </Operation>

</Patch>
