  <!-- ================================================================
       PASS 2: Add rechargeable comp.
       ================================================================ -->

  <!-- ==== BASIC TIER (maxCharge 100) ==== -->

  <!-- Specialized arm prosthetics — partEfficiency 1.0 default, offset leaves 50% -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/HediffDef[defName="DrillArm" or defName="FieldHand"]/comps</xpath>
    <value>
      <li Class="Chargeable_Hediffs_Framework.HediffCompProperties_Rechargeable">
        <maxCharge>100</maxCharge>
        <chargeDecayPerTick>0.0001666667</chargeDecayPerTick>
        <depletedConsequences>
          <partEfficiencyOffset>-0.50</partEfficiencyOffset>
        </depletedConsequences>
      </li>
    </value>
  </Operation>

  <!-- Neurocalculator: cancels ResearchSpeed +0.2 bonus -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/HediffDef[defName="Neurocalculator"]/comps</xpath>
    <value>
      <li Class="Chargeable_Hediffs_Framework.HediffCompProperties_Rechargeable">
        <maxCharge>100</maxCharge>
        <chargeDecayPerTick>0.0001666667</chargeDecayPerTick>
